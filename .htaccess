# Notice Manager - Security
# Prevent direct access to plugin files

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !^(.+)\.css$
RewriteCond %{REQUEST_FILENAME} !^(.+)\.js$
RewriteCond %{REQUEST_FILENAME} !^(.+)\.(png|jpg|jpeg|gif|svg|webp)$
RewriteRule ^(.*)$ - [F,L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^(readme\.txt|changelog\.txt|\.git|\.gitignore)$">
Order allow,deny
Deny from all
</FilesMatch>

